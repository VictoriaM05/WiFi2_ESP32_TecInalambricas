// ====== REDIRECCIÓN DEL PORTAL ======
// Fuerza al usuario a volver al portal si entra a otra página
void handleRedirect() {
  server.sendHeader("Location", "http://192.168.4.1/", true);
  server.send(302, "text/plain", "");
}

// Página principal del portal
void handleRoot() {
  server.send_P(200, "text/html", INDEX_HTML);
}

// Procesa el formulario del usuario
void handleConnect() {
  String nombre = server.arg("nombre");
  String cuarto  = server.arg("cuarto");

  // Validación 
  if (nombre.isEmpty() || cuarto.isEmpty()) {
    handleRedirect();
    return;
  }

  Serial.println("\n--- INFORMACIÓN DEL HUESPED ---");
  Serial.print("Huésped: "); Serial.println(nombre);
  Serial.print("Habitacion:  "); Serial.println(cuarto);

  // Muestra página de éxito
  server.send(200, "text/html", WELCOME_HTML);
}

void setup() {
  Serial.begin(115200);
  delay(2000);
  Serial.println("Iniciando...");

  // Modo dual: AP + STA
  WiFi.mode(WIFI_AP_STA);

  // Conexión a red externa (internet)
  WiFi.begin(STA_SSID, STA_PASS);
  Serial.print("Conectando...");

  int intentos = 0;
  while (WiFi.status() != WL_CONNECTED && intentos < 20) {
    delay(500);
    Serial.print(".");
    intentos++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nCONECTADO!");
  } else {
    Serial.println("\n[STA] No se pudo conectar, solo AP activo.");
  }

  // Crear red del portal cautivo
  WiFi.softAPConfig(AP_IP, AP_IP, AP_MASK);
  WiFi.softAP(AP_SSID);
  Serial.println("[AP] Red creada: " + String(AP_SSID));

  // DNS para redirigir todo al portal
  dnsServer.start(53, "*", AP_IP);

  // Rutas del servidor web
  server.on("/", HTTP_GET, handleRoot);
  server.on("/connect", HTTP_GET, handleConnect);
  server.on("/generate_204", HTTP_GET, handleRedirect);
  server.on("/hotspot-detect.html", HTTP_GET, handleRedirect);
  server.on("/connecttest.txt", HTTP_GET, handleRedirect);
  server.on("/ncsi.txt", HTTP_GET, handleRedirect);
  server.onNotFound(handleRedirect);

  server.begin();
}

void loop() {
  dnsServer.processNextRequest();
  server.handleClient();

  // Reintento de conexión si se pierde el WiFi externo
  static unsigned long lastCheck = 0;
  if (millis() - lastCheck > 5000) {
    lastCheck = millis();

    if (WiFi.status() != WL_CONNECTED) {
      Serial.println("[STA] Reconectando...");
      WiFi.reconnect();
    }
  }
}
